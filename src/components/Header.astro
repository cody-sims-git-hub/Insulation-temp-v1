---
import { Phone } from 'lucide-astro';
import MobileNav from '@/components/MobileNav.tsx';
import { business, nav, cta } from '@/data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="sticky top-0 z-40 px-3 pt-3 lg:px-5 lg:pt-4">
  <div class="mx-auto flex max-w-[84rem] items-center justify-between gap-4 rounded-full border border-ink/5 bg-cream/85 py-2.5 pl-3 pr-2.5 shadow-soft backdrop-blur-md lg:pl-4">
      <a href="/" class="flex items-center rounded-xl bg-ink px-3 py-2" aria-label="A Plus Insulation home">
        <img src="/photos/logo-wide.png" alt="A Plus Insulation" width="170" height="68" class="h-7 w-auto sm:h-8" />
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-full px-4 py-2 text-[0.95rem] font-medium transition-colors',
                isActive(item.href) ? 'bg-petrol/10 text-petrol' : 'text-ink-soft hover:bg-ink/5 hover:text-ink',
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden items-center gap-2 lg:flex">
        <a href={`tel:${business.phoneHref}`} class="flex items-center gap-2 rounded-full px-3 py-2 text-ink transition-colors hover:text-petrol">
          <Phone class="size-4" />
          <span class="text-[0.95rem] font-semibold">{business.phone}</span>
        </a>
        <a href={cta.href} class="btn btn-coral min-h-[2.75rem] px-5 text-[0.95rem]">{cta.label}</a>
      </div>

      <MobileNav
        client:load
        items={nav}
        phone={business.phone}
        phoneHref={business.phoneHref}
        ctaHref={cta.href}
        ctaLabel={cta.label}
      />
    </div>
  </header>
