---
import HeatLines from '@/components/HeatLines.astro';

interface Props {
  eyebrow: string;
  title: string;
  lead: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<section class="relative overflow-hidden px-4 pb-10 pt-12 lg:px-5 lg:pb-14 lg:pt-16">
  <HeatLines class="pointer-events-none absolute -top-24 right-0 h-[440px] w-[62%] text-petrol" opacity={0.08} />
  <div class="relative mx-auto max-w-[84rem]">
    <span class="tag" data-reveal>{eyebrow}</span>
    <h1 class="mt-6 max-w-5xl text-[2.85rem] leading-[0.92] text-ink sm:text-6xl lg:text-7xl" data-reveal>{title}</h1>
    <p class="lead mt-6 max-w-2xl" data-reveal>{lead}</p>
  </div>
</section>
