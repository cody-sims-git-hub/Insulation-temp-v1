---
import '@fontsource/bebas-neue';
import '@fontsource-variable/inter';
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { business, faqs } from '@/data/site';

interface Props {
  title: string;
  description: string;
  /** Emit FAQPage JSON-LD (home only). */
  faqSchema?: boolean;
  ogImage?: string;
}

const { title, description, faqSchema = false, ogImage = '/photos/fleet.jpg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'HomeAndConstructionBusiness'],
  name: business.name,
  description: 'Spray foam, blown-in & batt insulation for Random County homes. A Plus Insulation in Your City, FL — free estimates.',
  url: Astro.site?.href,
  telephone: business.phone,
  email: business.email,
  foundingDate: String(business.founded),
  image: ogImageUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.region,
    postalCode: business.address.postal,
    addressCountry: 'US',
  },
  areaServed: ['Your City FL', 'Random County FL', 'Sandy Creek FL', 'Grayson FL', 'Chandler FL', 'Ashford FL', 'Brookhaven FL'],
  knowsAbout: [
    'Spray foam insulation',
    'Blown-in insulation',
    'Batt and roll insulation',
    'Radiant barrier',
    'Insulation removal',
    'Insulation replacement',
  ],
  openingHoursSpecification: business.hours
    .filter((h) => !h.closed)
    .map((h) => ({
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: h.day,
      opens: '08:00',
      closes: '17:00',
    })),
  sameAs: [business.facebook],
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#123c42" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <set:html
      value={`<script type="application/ld+json">${JSON.stringify(localBusiness)}</script>`}
    />
    {faqSchema && (
      <set:html value={`<script type="application/ld+json">${JSON.stringify(faqPage)}</script>`} />
    )}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:bg-ink focus:px-4 focus:py-2 focus:text-paper"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      const reveal = () => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window) || matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
        // Failsafe: never leave content hidden if the observer misbehaves.
        setTimeout(() => els.forEach((el) => el.classList.add('is-visible')), 2500);
      };
      reveal();
      document.addEventListener('astro:after-swap', reveal);
    </script>
  </body>
</html>
