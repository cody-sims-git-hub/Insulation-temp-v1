---
import Base from '@/layouts/Base.astro';
import PageHero from '@/components/sections/PageHero.astro';
import CtaBand from '@/components/sections/CtaBand.astro';
import PanhandleMap from '@/components/PanhandleMap.astro';
import { MapPin, Phone, Navigation, Star } from 'lucide-astro';
import { seo, business, serviceAreas } from '@/data/site';
---

<Base title={seo.serviceArea.title} description={seo.serviceArea.description} ogImage="/photos/jobsite.jpg">
  <PageHero
    eyebrow="Service Area"
    title="Insulation Across Jackson County & the NW Florida Panhandle"
    lead="Based on Hwy 90 in Marianna, we cover Jackson County and travel roughly an hour in every direction — out toward Panama City, Dothan, DeFuniak Springs and the Georgia line. If your town is nearby and not listed, just call."
  />

  {/* The map — the centerpiece */}
  <section class="px-4 pb-4 pt-6 lg:px-5">
    <div class="mx-auto grid max-w-[84rem] gap-6 lg:grid-cols-5 lg:gap-7">
      <div class="surface p-5 sm:p-7 lg:col-span-3" data-reveal>
        <span class="tag">The territory</span>
        <h2 class="mt-4 text-4xl text-ink sm:text-5xl">One county at the heart of it</h2>
        <p class="mt-3 max-w-xl text-ink-soft">
          Jackson County is home base. The shaded counties are the ones we work in — across the
          Panhandle from the Gulf coast up into south Alabama and Georgia, Dothan and Enterprise to
          Tallahassee and Apalachicola.
        </p>
        <div class="mt-6">
          <PanhandleMap />
        </div>
      </div>

      <div class="flex flex-col gap-6 lg:col-span-2">
        <div class="surface p-7" data-reveal>
          <span class="grid size-11 place-items-center rounded-2xl bg-petrol/10 text-petrol">
            <MapPin class="size-5" />
          </span>
          <h3 class="mt-4 text-xl font-bold text-ink">Home base</h3>
          <p class="mt-2 leading-relaxed text-ink-soft">
            {business.address.street}, {business.address.city}, {business.address.region}{' '}
            {business.address.postal}. Right on Hwy 90 in the middle of the county — most estimates
            are a short drive from the shop.
          </p>
          <a
            href={business.mapsUrl}
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-petrol underline-offset-4 hover:underline"
          >
            <Navigation class="size-4" /> Get directions to the shop
          </a>
        </div>

        <div class="relative flex-1 overflow-hidden rounded-[1.75rem] bg-petrol p-8 text-cream shadow-lift" data-reveal>
          <h3 class="text-4xl">Not sure if we reach you?</h3>
          <p class="mt-3 leading-relaxed text-cream/80">
            If your town is close to the map and not on the list, odds are we cover it. Call and
            we’ll tell you in thirty seconds — and set up your free estimate while we’re at it.
          </p>
          <a href={`tel:${business.phoneHref}`} class="btn btn-coral mt-6 w-full sm:w-auto">
            <Phone class="size-4" /> Call {business.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Communities we serve */}
  <section class="px-4 py-12 lg:px-5 lg:py-16">
    <div class="mx-auto max-w-[84rem]">
      <span class="tag" data-reveal>Where we work</span>
      <h2 class="mt-4 text-5xl text-ink sm:text-6xl" data-reveal>Communities we serve</h2>
      <p class="lead mt-4 max-w-2xl" data-reveal>
        From the Marianna shop we cover the central Panhandle and reach into south Alabama and
        southwest Georgia. Here’s where we work, by area.
      </p>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          serviceAreas.map((a) => (
            <div class:list={['surface surface-lift p-6', { 'ring-2 ring-petrol/25': a.home }]} data-reveal>
              {a.home ? (
                <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-petrol">
                  <Star class="size-3.5 fill-coral text-coral" /> Home base · Florida
                </span>
              ) : (
                <span class="text-xs font-bold uppercase tracking-wide text-muted">{a.state}</span>
              )}
              <h3 class="mt-2 text-xl font-bold text-ink">{a.area}</h3>
              <p class="mt-3 leading-relaxed text-ink-soft">{a.towns.join(' · ')}</p>
            </div>
          ))
        }
      </div>
      <p class="mt-8 max-w-2xl text-ink-soft" data-reveal>
        Don’t see your town? It’s probably still in range — a lot of our work is a short drive from
        one of these. Call and we’ll tell you in thirty seconds.
      </p>
    </div>
  </section>

  <CtaBand />
</Base>
