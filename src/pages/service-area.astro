---
import Base from '@/layouts/Base.astro';
import PageHero from '@/components/sections/PageHero.astro';
import CtaBand from '@/components/sections/CtaBand.astro';
import { MapPin, Phone } from 'lucide-astro';
import { seo, business, serviceAreaTowns } from '@/data/site';
---

<Base title={seo.serviceArea.title} description={seo.serviceArea.description} ogImage="/photos/jobsite.jpg">
  <PageHero
    eyebrow="Service Area"
    title="Insulation Across Jackson County & the NW Florida Panhandle"
    lead="Based on Hwy 90 in Marianna, we cover Jackson County and the surrounding Panhandle. If your town is nearby and not listed, just call."
  />

  <section class="px-4 py-12 lg:px-5 lg:py-16">
    <div class="mx-auto grid max-w-[84rem] gap-12 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <span class="tag">Where we work</span>
        <h2 class="mt-4 text-5xl text-ink sm:text-6xl">Town by town</h2>
        <dl class="mt-8 grid gap-4">
          {
            serviceAreaTowns.map((town) => (
              <div class="surface p-6">
                <dt class="flex items-center gap-2.5 text-lg font-bold text-ink">
                  <span class="grid size-8 place-items-center rounded-full bg-petrol/10 text-petrol">
                    <MapPin class="size-4" />
                  </span>
                  {town.t}
                </dt>
                <dd class="mt-2 leading-relaxed text-ink-soft">{town.d}</dd>
              </div>
            ))
          }
        </dl>
        <p class="mt-8 text-ink-soft">
          Serving all of Jackson County and the surrounding Panhandle, including nearby communities like Cypress.
        </p>
      </div>

      <div class="space-y-6 lg:sticky lg:top-28 lg:self-start" data-reveal>
        <div class="overflow-hidden rounded-[1.75rem] shadow-lift">
          <iframe
            title="A Plus Insulation service area map — Marianna, FL"
            width="100%"
            height="420"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src={business.mapsEmbed}></iframe>
        </div>
        <div class="relative overflow-hidden rounded-[1.75rem] bg-petrol p-8 text-cream shadow-lift">
          <h3 class="text-4xl">Not sure if we reach you?</h3>
          <p class="mt-3 leading-relaxed text-cream/80">
            If your town is close to the map and not on the list, odds are we cover it. Call and we’ll tell you in thirty
            seconds — and set up your free estimate while we’re at it.
          </p>
          <a href={`tel:${business.phoneHref}`} class="btn btn-coral mt-6 w-full sm:w-auto">
            <Phone class="size-4" /> Call {business.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
