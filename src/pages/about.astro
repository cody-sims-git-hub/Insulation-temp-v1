---
import Base from '@/layouts/Base.astro';
import CtaBand from '@/components/sections/CtaBand.astro';
import Icon from '@/components/Icon.astro';
import { Check, MapPin } from 'lucide-astro';
import { seo, about } from '@/data/site';
---

<Base title={seo.about.title} description={seo.about.description} ogImage="/photos/foam-walls.jpg">
  {/* Hero + intro — the photo fills the right column so there's no dead space */}
  <section class="px-4 pb-8 pt-12 lg:px-5 lg:pt-16">
    <div class="mx-auto grid max-w-[84rem] items-stretch gap-10 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-7" data-reveal>
        <span class="tag">About</span>
        <h1 class="mt-6 text-[2.6rem] leading-[0.95] text-ink sm:text-6xl lg:text-[3.9rem]">
          {about.hero.title}
        </h1>
        <p class="lead mt-6 max-w-xl">{about.hero.lead}</p>
        <div class="mt-8 space-y-5 border-t border-ink/10 pt-8">
          {about.intro.map((p) => <p class="text-lg leading-relaxed text-ink-soft">{p}</p>)}
        </div>
        <p class="mt-8 font-display text-3xl leading-none text-petrol sm:text-4xl">
          — The A Plus family, Marianna FL
        </p>
      </div>
      <div class="relative lg:col-span-5" data-reveal>
        {/* Absolutely filled on desktop so the text sets the height — the
            portrait photo can't push the row taller and leave blank space. */}
        <div class="duotone min-h-[22rem] w-full shadow-lift lg:absolute lg:inset-0 lg:h-full lg:min-h-0">
          <img
            src="/photos/foam-ceiling.jpg"
            alt="Spray foam insulation applied to a ceiling by A Plus Insulation"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Values band */}
  <section class="px-4 pb-4 pt-8 lg:px-5 lg:pt-14">
    <div class="mx-auto grid max-w-[84rem] gap-5 sm:grid-cols-3">
      {
        about.values.map((v) => (
          <div class="surface surface-lift p-7" data-reveal>
            <span class="grid size-12 place-items-center rounded-2xl bg-petrol/10 text-petrol">
              <Icon name={v.i} class="size-6" />
            </span>
            <h3 class="mt-4 text-lg font-bold text-ink">{v.t}</h3>
            <p class="mt-1 text-muted">{v.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Story + stats */}
  <section class="px-4 py-8 lg:px-5 lg:py-12">
    <div class="mx-auto grid max-w-[84rem] gap-12 rounded-[2rem] bg-cream p-8 shadow-soft lg:grid-cols-2 lg:gap-16 lg:p-14">
      <div data-reveal>
        <span class="tag">Our story</span>
        <h2 class="mt-4 text-5xl text-ink sm:text-6xl">20 years, one county</h2>
        {about.story.map((p) => <p class="mt-5 leading-relaxed text-ink-soft">{p}</p>)}
      </div>
      <div class="grid content-start gap-4 sm:grid-cols-2" data-reveal>
        <div class="rounded-2xl bg-canvas p-6">
          <span class="font-display text-5xl text-petrol">2006</span>
          <p class="mt-2 text-sm font-bold uppercase tracking-wide text-ink">The year we started</p>
          <p class="mt-1 text-sm text-muted">Insulating Panhandle homes ever since.</p>
        </div>
        <div class="rounded-2xl bg-canvas p-6">
          <span class="font-display text-5xl text-petrol">20</span>
          <p class="mt-2 text-sm font-bold uppercase tracking-wide text-ink">Years family-run</p>
          <p class="mt-1 text-sm text-muted">Same family, same standards, no franchises.</p>
        </div>
        <div class="rounded-2xl bg-canvas p-6 sm:col-span-2">
          <span class="grid size-11 place-items-center rounded-2xl bg-petrol/10 text-petrol"><MapPin class="size-5" /></span>
          <p class="mt-3 text-sm font-bold uppercase tracking-wide text-ink">Home base: Hwy 90, Marianna</p>
          <p class="mt-1 text-sm text-muted">Right in the middle of Jackson County — most estimates are a short drive from the shop.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Commitments */}
  <section class="px-4 py-12 lg:px-5 lg:py-16">
    <div class="mx-auto max-w-[84rem]">
      <span class="tag" data-reveal>How we work</span>
      <h2 class="mt-4 text-5xl text-ink sm:text-6xl" data-reveal>Four commitments on every job</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        {
          about.commitments.map((c) => (
            <div class="surface flex gap-4 p-7" data-reveal>
              <span class="mt-0.5 grid size-9 shrink-0 place-items-center rounded-full bg-petrol text-cream">
                <Check class="size-5" />
              </span>
              <div>
                <h3 class="text-lg font-bold text-ink">{c.t}</h3>
                <p class="mt-1 text-muted">{c.d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Details band */}
  <section class="px-4 py-8 lg:px-5 lg:py-12">
    <div class="mx-auto max-w-[84rem] rounded-[2rem] bg-petrol px-6 py-12 text-cream shadow-lift lg:px-14">
      <div class="grid gap-8 sm:grid-cols-3">
        {
          about.details.map((d) => (
            <div class="flex gap-3" data-reveal>
              <span class="mt-0.5 shrink-0 text-honey"><Check class="size-5" /></span>
              <div>
                <h3 class="text-sm font-bold uppercase tracking-wide">{d.t}</h3>
                <p class="mt-1 text-sm text-cream/80">{d.d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
