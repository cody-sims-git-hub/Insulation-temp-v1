{
  "name": "sdp-starter-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Build pipeline for the SDP Starter WordPress theme (Tailwind v4 + Alpine).",
  "scripts": {
    "build:css": "tailwindcss -i ./src/app.css -o ./dist/app.css --minify",
    "build:js": "esbuild src/app.js --bundle --minify --outfile=dist/app.js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -i ./src/app.css -o ./dist/app.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "alpinejs": "^3.14.8"
  }
}
