{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"palette": [
				{ "slug": "ink", "color": "#1b2a20", "name": "Ink" },
				{ "slug": "muted", "color": "#55635a", "name": "Muted" },
				{ "slug": "surface", "color": "#f1ede4", "name": "Surface" },
				{ "slug": "accent", "color": "#2f5d3a", "name": "Accent" },
				{ "slug": "cta", "color": "#bd5f30", "name": "CTA" },
				{ "slug": "bg", "color": "#faf8f3", "name": "Background" }
			]
		},
		"typography": {
			"fontFamilies": [
				{ "fontFamily": "'IBM Plex Sans', ui-sans-serif, system-ui, sans-serif", "slug": "sans", "name": "IBM Plex Sans" },
				{ "fontFamily": "'IBM Plex Mono', ui-monospace, monospace", "slug": "mono", "name": "IBM Plex Mono" }
			]
		},
		"layout": { "contentSize": "44rem", "wideSize": "72rem" }
	},
	"styles": {
		"color": { "background": "#faf8f3", "text": "#1b2a20" }
	}
}
