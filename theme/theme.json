{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"palette": [
				{ "slug": "ink", "color": "#14161a", "name": "Ink" },
				{ "slug": "muted", "color": "#5b616e", "name": "Muted" },
				{ "slug": "surface", "color": "#f6f7f9", "name": "Surface" },
				{ "slug": "accent", "color": "#4f46e5", "name": "Accent" },
				{ "slug": "bg", "color": "#ffffff", "name": "Background" }
			]
		},
		"typography": {
			"fontFamilies": [
				{ "fontFamily": "'Inter', ui-sans-serif, system-ui, sans-serif", "slug": "sans", "name": "Inter" }
			]
		},
		"layout": { "contentSize": "44rem", "wideSize": "72rem" }
	},
	"styles": {
		"color": { "background": "#ffffff", "text": "#14161a" }
	}
}
